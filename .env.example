# Wholesaler CRM — Environment Configuration

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/wholesaler_crm"

# For Vercel deployment:
# 1. Set DATABASE_URL in Vercel dashboard → Settings → Environment Variables
# 2. Use Vercel Postgres, Neon, or Supabase connection string
# 3. Vercel Postgres example:
#    DATABASE_URL="postgres://default:xxxxx@ep-xxxxx.us-east-1.aws.neon.tech/wholesaler-crm?sslmode=require"
# 4. For connection pooling, add ?pgbouncer=true to the URL

# Next.js
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth (future: NextAuth.js secret)
# NEXTAUTH_SECRET="your-secret-here"
# NEXTAUTH_URL="http://localhost:3000"
